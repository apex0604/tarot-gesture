# Required when AI_PROVIDER=doubao
AI_PROVIDER=doubao
DOUBAO_API_KEY=replace-with-your-doubao-or-ark-api-key
DOUBAO_MODEL=doubao-seed-1-6-flash-250828
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Required only when AI_PROVIDER=openai
# AI_PROVIDER=openai
# OPENAI_API_KEY=replace-with-your-openai-api-key
# OPENAI_MODEL=gpt-4.1-mini

# Public server settings
HOST=0.0.0.0
PORT=5173
PUBLIC_ORIGIN=https://your-domain.example

# Optional: only needed if another domain calls /api/reading directly.
# Same-origin website usage can leave this empty.
ALLOWED_ORIGINS=https://your-domain.example

# Basic in-memory protection for /api/reading.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
MAX_BODY_BYTES=20480
